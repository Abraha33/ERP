# =============================================================================
# ERP Satélite — variables canónicas (sin secretos reales). Copiar a .env
# Cliente Android: inyectar equivalentes vía Gradle / BuildConfig según ADR-001.
# =============================================================================

# Supabase (app + scripts)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres directo (scripts Python, herramientas locales)
DATABASE_URL=

# SAE — rutas de import/export
SAE_EXPORT_PATH=
SAE_IMPORT_PATH=

# Scraper opcional (Playwright)
PLAYWRIGHT_HEADLESS=true

# Worker FastAPI opcional (tools/worker/)
FASTAPI_SECRET_KEY=
ALLOWED_ORIGINS=http://localhost:8000

# Fase 4+ (placeholders)
OPENAI_API_KEY=
WHATSAPP_CLOUD_TOKEN=

# Entorno lógico (local / staging / prod)
ERP_ENVIRONMENT=development

# CI — no commitear; usar GitHub Secrets
CI_SUPABASE_ACCESS_TOKEN=

# Identificador de aplicación Android (referencia para Gradle)
ANDROID_APPLICATION_ID=com.erp.satelite
