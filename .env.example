# =============================================
# VARIABLES DE ENTORNO — ERP Satélite
# Copiar a .env en la raíz de erp-satelite y rellenar.
# Para `expo start` desde apps/mobile, Expo lee apps/mobile/.env — puedes copiar solo las
# variables EXPO_PUBLIC_* allí o enlazar; ver apps/mobile/.env.example.
# NUNCA subir .env al repositorio (ver README §8).
# Alineado a ADR-001 (Supabase + FastAPI worker + Expo + Playwright).
#
# Estado fundación (Fase 0): proyecto Supabase + claves en .env local +
# EXPO_PUBLIC_* y DATABASE_URL — En progreso (mismo criterio que README §16).
# =============================================

# --- Supabase (Project Settings → API / Database) — En progreso hasta crear proyecto y pegar valores
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Project ref para CLI/deploy (ej. fwegtmgcuuyjryffkmxb)
SUPABASE_PROJECT_REF=fwegtmgcuuyjryffkmxb
# Solo servidor / scripts locales; NUNCA en app Expo ni en repo público:
SUPABASE_SERVICE_ROLE_KEY=

# --- FastAPI worker
# Cadena Postgres (p. ej. "Connection string" modo session o pooler en Supabase)
DATABASE_URL=
FASTAPI_SECRET_KEY=
# CORS: lista separada por comas, ej. http://localhost:8081,https://tu-dominio.app
ALLOWED_ORIGINS=

# --- Expo / app (públicas en el bundle; usar solo anon key, nunca service_role)
# Suele coincidir con SUPABASE_URL y SUPABASE_ANON_KEY
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_API_BASE_URL=

# --- Playwright / SAE scraper
SAE_USER=
SAE_PASSWORD=
SAE_BASE_URL=
PLAYWRIGHT_HEADLESS=true

# --- WhatsApp (Fase 4 — dejar vacíos hasta entonces)
WHATSAPP_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# --- Transcripción audio (Fase 4)
OPENAI_API_KEY=

# --- Diagnóstico RLS (script scripts/rls-diagnostics — usuarios reales en Auth + filas en public.profiles)
# RLS_TEST_ADMIN_EMAIL=
# RLS_TEST_ENCARGADO_EMAIL=
# RLS_TEST_EMPLEADO_EMAIL=
# RLS_TEST_PASSWORD=
# UUIDs de tenant de prueba (mismos que en profiles de esos usuarios)
# RLS_TEST_EMPRESA_ID=
# RLS_TEST_SUCURSAL_ID=

# --- CI / EAS (configurar en GitHub Secrets / EAS, no en .env local del repo)
# EXPO_TOKEN=
# SUPABASE_ACCESS_TOKEN=
# SUPABASE_DB_URL=
