# =============================================================================
# ERP Satélite — variables canónicas (sin secretos reales)
#
# Uso: copiar a `.env` en la raíz del monorepo y rellenar valores reales.
#       Nunca commitear `.env`, `.env.local` ni claves.
#
# Cliente Android (producto): equivalentes vía Gradle / BuildConfig / local.properties
# (ver ADR-001). En el APK solo URL pública + anon key; NUNCA service_role.
#
# Leyenda:
#   [REQUERIDO]     — necesario para el flujo mínimo indicado en cada bloque
#   [OPCIONAL]      — solo si usas esa herramienta o integración
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — cliente (PostgREST, Auth, Realtime, RPC)  [REQUERIDO para app / SDK]
# -----------------------------------------------------------------------------
# URL del proyecto: Dashboard → Settings → API → Project URL
SUPABASE_URL=https://xxxxxxxx.supabase.co

# Clave anónima (public): Dashboard → Settings → API → anon public
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.replace-with-your-anon-key

# -----------------------------------------------------------------------------
# Supabase — privilegiado  [OPCIONAL; solo entornos de confianza: scripts locales, CI, ETL]
# -----------------------------------------------------------------------------
# Service role: bypass RLS. NO empaquetar en APK ni exponer al cliente móvil.
SUPABASE_SERVICE_ROLE_KEY=

# Connection string Postgres (modo sesión o URI del proyecto). Útil para:
#   - `supabase db push --db-url "$SUPABASE_DB_URL"` (mismo nombre que secret GitHub Actions)
#   - herramientas que hablen SQL directo
SUPABASE_DB_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres

# -----------------------------------------------------------------------------
# Postgres genérico  [OPCIONAL; scripts Python / herramientas que usen libpq sin prefijo Supabase]
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/postgres

# -----------------------------------------------------------------------------
# Diagnóstico RLS (scripts/rls-diagnostics)  [OPCIONAL; requiere usuarios de prueba en Auth + profiles]
# -----------------------------------------------------------------------------
# Docs: docs/reference/SUPABASE_CLI_VERSIONING.md §9
RLS_TEST_ADMIN_EMAIL=
RLS_TEST_ENCARGADO_EMAIL=
RLS_TEST_EMPLEADO_EMAIL=
RLS_TEST_PASSWORD=
RLS_TEST_EMPRESA_ID=
RLS_TEST_SUCURSAL_ID=

# -----------------------------------------------------------------------------
# Supabase CLI — deploy local manual  [OPCIONAL]
# -----------------------------------------------------------------------------
# Token personal: https://supabase.com/dashboard/account/tokens
# En GitHub Actions el secret se llama igual: SUPABASE_ACCESS_TOKEN
SUPABASE_ACCESS_TOKEN=

# Referencia del proyecto (subdominio antes de .supabase.co). En Actions: variable SUPABASE_PROJECT_REF
SUPABASE_PROJECT_REF=

# -----------------------------------------------------------------------------
# SAE — import / export / scraper  [OPCIONAL]
# -----------------------------------------------------------------------------
SAE_EXPORT_PATH=
SAE_IMPORT_PATH=
# Scraper Playwright (tools/scraper/): URL base del sistema legacy cuando exista flujo
SAE_BASE_URL=

# -----------------------------------------------------------------------------
# Playwright  [OPCIONAL]
# -----------------------------------------------------------------------------
PLAYWRIGHT_HEADLESS=true

# -----------------------------------------------------------------------------
# Worker FastAPI (tools/worker/)  [OPCIONAL]
# -----------------------------------------------------------------------------
FASTAPI_SECRET_KEY=change-me-in-production
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# -----------------------------------------------------------------------------
# Cliente móvil legado (apps/mobile / Expo)  [OPCIONAL; no es stack de producto]
# -----------------------------------------------------------------------------
# Si mantienes rutas de desarrollo en Expo, pueden leer estos nombres. El SDK en
# rls-diagnostics acepta SUPABASE_* con fallback a EXPO_PUBLIC_*.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# Fase 4+ (placeholders)  [OPCIONAL]
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
WHATSAPP_CLOUD_TOKEN=

# -----------------------------------------------------------------------------
# Entorno lógico  [OPCIONAL; convención interna]
# -----------------------------------------------------------------------------
# Valores típicos: development | staging | production
ERP_ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Scripts GitHub / monorepo  [OPCIONAL en .env local]
# -----------------------------------------------------------------------------
# Repo `owner/name` para scripts Python (sync milestones, etc.)
GH_REPO=

# En GitHub Actions: secret PROJECTS_TOKEN (PAT con scope project) para Projects API.
# No suele necesitarse en `.env` local salvo que ejecutes automatizaciones contra la API.

# -----------------------------------------------------------------------------
# Android (referencia para Gradle cuando exista apps/android/)  [OPCIONAL]
# -----------------------------------------------------------------------------
ANDROID_APPLICATION_ID=com.erp.satelite
