# Nombre exacto del archivo: .env (con v), junto a package.json y app.config.js.
# Si Windows te creó .env.txt, desactiva «Ocultar extensiones» y renómbralo a .env
# o déjalo como .env.txt — app.config.js también lo lee.
# También se acepta .en por error de nombre (mejor renombrar a .env).

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Tras cambiar valores: detén Metro y ejecuta: npx expo start --clear
